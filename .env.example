# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/tattoo_record
PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password
PGDATABASE=tattoo_record

# Authentication
JWT_SECRET=tattoo-record-secret-key-change-in-production
SESSION_SECRET=session-secret-key-change-in-production

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Anthropic Configuration (Phase 1 AI auto-tagging + digest)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Voyage AI Configuration (Phase 3 semantic search embeddings)
VOYAGE_API_KEY=your_voyage_api_key

# AI Feature Flags (set to "false" to disable a feature)
AI_AUTOTAG=true
AI_DIGEST=true
AI_SEMANTIC_SEARCH=true

# Application Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
NODE_ENV=development
PORT=5000

# WebSocket Configuration
WEBSOCKET_HEARTBEAT_MS=30000

# Story Configuration
STORY_TTL_HOURS=24
